# === Gemini (same key as NobleVerse) ===
GEMINI_API_KEY=your_gemini_api_key_here

# === PostgreSQL ===
DATABASE_URL=postgresql://noble:CHANGE_THIS@127.0.0.1:5432/noble_intel

# === Qdrant ===
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=intel_signals

# === Redis (Celery broker) ===
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@127.0.0.1:6379/0

# === Supabase (for pushing P0 alerts) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# === Intel API ===
INTEL_API_KEY=generate_a_strong_random_key_here
INTEL_API_PORT=8000

# === Sentry ===
SENTRY_DSN=

# === Proxy (Phase 2) ===
# PROXY_URL=http://user:pass@proxy.example.com:8080
